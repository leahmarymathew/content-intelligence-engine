# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_content
# For SQLite (development): sqlite:///./content.db

# Authentication
SECRET_KEY=your-secret-key-minimum-32-characters-long-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI API (optional)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Groq API — free at console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# MongoDB — for RAG document metadata (optional but recommended)
# Free tier: MongoDB Atlas at cloud.mongodb.com
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-domain.vercel.app

# Environment
ENVIRONMENT=production
# Options: development, staging, production

# Port
PORT=8000

# Logging
LOG_LEVEL=info
# Options: debug, info, warning, error, critical
